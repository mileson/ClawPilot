# ===== CJFClawPilot Environment Variables =====
# Usage: cp .env.example .env, then fill in your values.

# ---- API / Web Base Config ----
OPENCLAW_API_BASE=http://clawpilot:8088
OPENCLAW_PROXY_BASE=http://clawpilot:8088
NEXT_PUBLIC_API_BASE=

# ---- Data Paths ----
OPENCLAW_OPS_DB=/data/openclaw_ops.db
OPENCLAW_SCENE_ASSET_DIR=/data/scene-assets
OPENCLAW_CONFIG_PATH=/host-openclaw/openclaw.json
OPENCLAW_ROSTER_PATH=/host-openclaw/workspace/dispatch/agent-roster.json
OPENCLAW_PUBLIC_BASE_URL=
OPENCLAW_PUBLIC_SITE_ADDRESS=
OPENCLAW_PUBLIC_MODE=
OPENCLAW_PUBLIC_HOST_IP=
OPENCLAW_PUBLIC_WEB_PORT=13000
NODE_CONNECTOR_ONLINE_THRESHOLD_SEC=90

# ---- Edition Gate ----
# Set to "public" for the open-source edition (limits nav to core pages)
NEXT_PUBLIC_EDITION=public

# ---- Feishu User Auth (optional) ----
FEISHU_USER_AUTH_AGENT_IDS=
FEISHU_USER_AUTH_USER_KEY=default-human
FEISHU_USER_AUTH_SCOPE=im:message.send_as_user
FEISHU_USER_AUTH_STATE_TTL_SEC=900
FEISHU_USER_TOKEN_REFRESH_BUFFER_SEC=300

# ---- Agent Scene Avatar Generation ----
# Provider: apimart | openrouter | auto
AGENT_SCENE_PROVIDER=auto
# Fall back to local animation sprites when API fails (recommended for first-time users)
AGENT_SCENE_LOCAL_FALLBACK=true
# Scene task cache (prevents duplicate submissions / charges)
AGENT_SCENE_TASK_CACHE_PATH=/data/scene-task-cache.json

# Sprite sheet parameters (21:9 + 1K recommended)
AGENT_SCENE_ASPECT_RATIO=21:9
AGENT_SCENE_RESOLUTION=1K
AGENT_SCENE_FPS=4

# APIMart (recommended) — leave empty to disable
AGENT_SCENE_APIMART_API_URL=https://api.apimart.ai/v1/images/generations
AGENT_SCENE_APIMART_TASK_URL=https://api.apimart.ai/v1/tasks
AGENT_SCENE_APIMART_MODEL=gemini-2.5-flash-image-preview
AGENT_SCENE_APIMART_API_TOKEN=
AGENT_SCENE_APIMART_POLL_INTERVAL_SEC=5
AGENT_SCENE_APIMART_POLL_MAX_RETRIES=120

# OpenRouter (fallback) — leave empty to disable
AGENT_SCENE_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
AGENT_SCENE_OPENROUTER_MODEL=google/gemini-2.5-flash-image-preview
AGENT_SCENE_OPENROUTER_API_KEY=
